generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  WORKER
  ADMIN
}

enum JobUrgency {
  LOW
  MEDIUM
  HIGH
}

enum JobStatus {
  POSTED
  APPLIED
  SHORTLISTED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  REVIEWED
  CANCELLED
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  REJECTED
  ACCEPTED
  WITHDRAWN
}

enum BookingStatus {
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  REVIEWED
  CANCELLED
}

enum NotificationType {
  APPLICATION_NEW
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  MESSAGE_NEW
  BOOKING_CONFIRMED
  JOB_COMPLETED
  REVIEW_RECEIVED
}

model User {
  id                  String         @id @default(cuid())
  phone               String         @unique
  email               String?        @unique
  passwordHash        String
  role                Role
  name                String
  languagePreference  String         @default("en")
  isActive            Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  ownerProfile        OwnerProfile?
  workerProfile       WorkerProfile?

  jobs                Job[]          @relation("OwnerJobs")
  applications        JobApplication[]
  workerBookings      Booking[]      @relation("WorkerBookings")
  givenReviews        Review[]       @relation("GivenReviews")
  receivedReviews     Review[]       @relation("ReceivedReviews")
  sentMessages        Message[]      @relation("SentMessages")
  receivedMessages    Message[]      @relation("ReceivedMessages")
  notifications       Notification[]
  adminActions        AdminAction[]  @relation("AdminActor")
  savedJobs           SavedJob[]
}

model OwnerProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  organization  String?
  address       String?
  whatsapp      String?
  verificationBadge Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkerProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  location            String
  skills              String[]
  experienceYears     Int       @default(0)
  expectedWage        Int
  availability        String
  profilePhotoUrl     String?
  idVerificationStatus String   @default("PENDING")
  bio                 String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id                  String          @id @default(cuid())
  ownerId             String
  title               String
  category            String
  description         String
  budgetMin           Int
  budgetMax           Int
  location            String
  requiredDateTime    DateTime
  workersRequired     Int
  skillRequirement    String[]
  contactPreference   String
  urgency             JobUrgency
  imageUrls           String[]
  status              JobStatus       @default(POSTED)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  owner               User            @relation("OwnerJobs", fields: [ownerId], references: [id], onDelete: Cascade)
  applications        JobApplication[]
  bookings            Booking[]
  reviews             Review[]
  messages            Message[]
  savedBy             SavedJob[]

  @@index([category, location, urgency])
}

model JobApplication {
  id                  String            @id @default(cuid())
  jobId               String
  workerId            String
  coverMessage        String?
  proposedWage        Int?
  status              ApplicationStatus @default(APPLIED)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  job                 Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker              User              @relation(fields: [workerId], references: [id], onDelete: Cascade)
  booking             Booking?

  @@unique([jobId, workerId])
}

model Booking {
  id                  String        @id @default(cuid())
  jobId               String
  applicationId       String        @unique
  workerId            String
  ownerId             String
  status              BookingStatus @default(CONFIRMED)
  progressNote        String?
  confirmedAt         DateTime      @default(now())
  completedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  job                 Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  application         JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  worker              User          @relation("WorkerBookings", fields: [workerId], references: [id], onDelete: Cascade)
}

model Review {
  id                  String      @id @default(cuid())
  jobId               String
  bookingId           String      @unique
  reviewerId          String
  revieweeId          String
  rating              Int
  comment             String?
  createdAt           DateTime    @default(now())

  job                 Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reviewer            User        @relation("GivenReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee            User        @relation("ReceivedReviews", fields: [revieweeId], references: [id], onDelete: Cascade)
}

model Message {
  id                  String      @id @default(cuid())
  jobId               String
  senderId            String
  receiverId          String
  content             String
  createdAt           DateTime    @default(now())

  job                 Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sender              User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver            User        @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Notification {
  id                  String            @id @default(cuid())
  userId              String
  type                NotificationType
  title               String
  body                String
  isRead              Boolean           @default(false)
  metadata            Json?
  createdAt           DateTime          @default(now())

  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminAction {
  id                  String      @id @default(cuid())
  adminId             String
  targetUserId        String?
  targetJobId         String?
  actionType          String
  reason              String?
  metadata            Json?
  createdAt           DateTime    @default(now())

  admin               User        @relation("AdminActor", fields: [adminId], references: [id], onDelete: Cascade)
}

model SavedJob {
  id                  String      @id @default(cuid())
  workerId            String
  jobId               String
  createdAt           DateTime    @default(now())

  worker              User        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  job                 Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([workerId, jobId])
}
